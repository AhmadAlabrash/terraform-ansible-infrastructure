pipeline {
    agent any

    environment {
        AWS_ACCOUNT_ID     = '612990353866'
        AWS_DEFAULT_REGION = 'us-east-1'

        TF_VAR_key_name    = 'nextjob-key'

        ECR_REPO           = 'nextjob-platform'
        IMAGE_TAG          = "${BUILD_NUMBER}"
        IMAGE_REPO         = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com/${ECR_REPO}"
        IMAGE_URI          = "${IMAGE_REPO}:${IMAGE_TAG}"

        SONARQUBE_ENV      = 'sonarqube-server'
    }

    stages {
        stage('Debug Environment') {
            steps {
                sh 'whoami'
                sh 'pwd'
                sh 'aws sts get-caller-identity'
                sh 'docker --version'
                sh 'node --version'
                sh 'npm --version'
            }
        }

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/AhmadAlabrash/terraform-ansible-infrastructure'
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('app') {
                    sh 'npm install'
                }
            }
        }

        stage('Build NextJob App') {
            steps {
                dir('app') {
                    sh 'npm run build'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('app') {
                    withSonarQubeEnv("${SONARQUBE_ENV}") {
                        sh '''
                            npx sonar-scanner \
                              -Dsonar.projectKey=nextjob-platform \
                              -Dsonar.projectName="NextJob Platform" \
                              -Dsonar.sources=. \
                              -Dsonar.exclusions=node_modules/**,.next/** \
                              -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('app') {
                    sh '''
                        docker build -t ${ECR_REPO}:${IMAGE_TAG} .
                        docker tag ${ECR_REPO}:${IMAGE_TAG} ${IMAGE_URI}
                    '''
                }
            }
        }

        stage('Push Docker Image to ECR') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-creds'
                ]]) {
                    sh '''
                        aws ecr describe-repositories --repository-names ${ECR_REPO} --region ${AWS_DEFAULT_REGION} || \
                        aws ecr create-repository --repository-name ${ECR_REPO} --region ${AWS_DEFAULT_REGION}

                        aws ecr get-login-password --region ${AWS_DEFAULT_REGION} | \
                        docker login --username AWS --password-stdin \
                        ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com

                        docker push ${IMAGE_URI}
                    '''
                }
            }
        }

        stage('Terraform Init') {
            steps {
                dir('terraform') {
                    sh 'terraform init'
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                dir('terraform') {
                    sh 'terraform apply -auto-approve'
                }
            }
        }

        stage('Update Inventory') {
            steps {
                script {
                    def appIp = sh(
                        script: "cd terraform && terraform output -raw app_server_public_ip",
                        returnStdout: true
                    ).trim()

                    sh """
                    cat > ansible/inventory.ini <<EOF
[app]
${appIp} ansible_user=ec2-user
EOF
                    """
                }
            }
        }

        stage('Deploy NextJob Platform') {
            steps {
                dir('ansible') {
                    sh """
                        ansible-playbook playbook.yml \
                          --extra-vars "docker_image=${IMAGE_URI}"
                    """
                }
            }
        }
    }

    post {
        success {
            echo 'NextJob Platform pipeline completed successfully.'
        }
        failure {
            echo 'NextJob Platform pipeline failed.'
        }
    }
}