pipeline {
    agent any

    environment {
        AWS_DEFAULT_REGION = 'us-east-1'
        TF_VAR_key_name = 'nextjob-key'
    }

    stages {
        stage('Debug Environment') {
            steps {
                sh 'whoami'
                sh 'pwd'
                sh 'aws sts get-caller-identity'
            }
        }

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'YOUR_GITHUB_REPO_URL'
            }
        }

        stage('Build NextJob App') {
            steps {
                dir('app') {
                    sh 'npm install'
                    sh 'npm run build'
                }
            }
        }

        stage('Terraform Init') {
            steps {
                dir('terraform') {
                    sh 'terraform init'
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                dir('terraform') {
                    sh 'terraform apply -auto-approve'
                }
            }
        }

        stage('Update Inventory') {
            steps {
                script {
                    def appIp = sh(
                        script: "cd terraform && terraform output -raw app_server_public_ip",
                        returnStdout: true
                    ).trim()

                    sh """
                    cat > ansible/inventory.ini <<EOF
[app]
${appIp} ansible_user=ec2-user
EOF
                    """
                }
            }
        }

        stage('Deploy NextJob Platform') {
            steps {
                dir('ansible') {
                    sh 'ansible-playbook playbook.yml'
                }
            }
        }
    }
}
