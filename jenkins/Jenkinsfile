pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    environment {
        AWS_ACCOUNT_ID     = '612990353866'
        AWS_DEFAULT_REGION = 'us-east-1'

        TF_VAR_key_name    = 'nextjob-key'

        ECR_REPO           = 'nextjob-platform'
        IMAGE_TAG          = "${BUILD_NUMBER}"
        IMAGE_REPO         = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com/${ECR_REPO}"
        IMAGE_URI          = "${IMAGE_REPO}:${IMAGE_TAG}"

        SONARQUBE_ENV      = 'sonarqube-server'
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/AhmadAlabrash/terraform-ansible-infrastructure.git'
            }
        }

        stage('Debug Environment') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-creds'
                ]]) {
                    sh '''
                        whoami
                        pwd
                        aws sts get-caller-identity
                        docker --version
                        node --version
                        npm --version
                        terraform version
                        ansible --version
                    '''
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('app') {
                    sh 'npm install'
                }
            }
        }

        stage('Build App') {
            steps {
                dir('app') {
                    sh 'npm run build'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('app') {
                    withSonarQubeEnv("${SONARQUBE_ENV}") {
                        sh '''
                            npx sonar-scanner \
                              -Dsonar.projectKey=nextjob-platform \
                              -Dsonar.projectName="NextJob Platform" \
                              -Dsonar.sources=. \
                              -Dsonar.exclusions=node_modules/**,.next/**,.git/** \
                              -Dsonar.sourceEncoding=UTF-8
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('app') {
                    sh '''
                        docker build -t ${ECR_REPO}:${IMAGE_TAG} .
                        docker tag ${ECR_REPO}:${IMAGE_TAG} ${IMAGE_URI}
                    '''
                }
            }
        }

        stage('Push Docker Image to ECR') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-creds'
                ]]) {
                    sh '''
                        aws ecr describe-repositories --repository-names ${ECR_REPO} --region ${AWS_DEFAULT_REGION} >/dev/null 2>&1 || \
                        aws ecr create-repository --repository-name ${ECR_REPO} --region ${AWS_DEFAULT_REGION}

                        aws ecr get-login-password --region ${AWS_DEFAULT_REGION} | \
                        docker login --username AWS --password-stdin ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com

                        docker push ${IMAGE_URI}
                    '''
                }
            }
        }

        stage('Terraform Init') {
            steps {
                dir('terraform') {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-creds'
                    ]]) {
                        sh 'terraform init'
                    }
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                dir('terraform') {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-creds'
                    ]]) {
                        sh 'terraform apply -auto-approve'
                    }
                }
            }
        }

        stage('Update Inventory') {
            steps {
                script {
                    def appIp = sh(
                        script: "cd terraform && terraform output -raw app_server_public_ip",
                        returnStdout: true
                    ).trim()

                    sh """
                        cat > ansible/inventory.ini <<EOF
[app]
${appIp} ansible_user=ec2-user
EOF
                    """
                }
            }
        }

        stage('Wait for SSH') {
            steps {
                script {
                    def appIp = sh(
                        script: "cd terraform && terraform output -raw app_server_public_ip",
                        returnStdout: true
                    ).trim()

                    sh """
                        echo "Waiting for SSH on ${appIp}..."
                        for i in {1..30}; do
                          nc -z ${appIp} 22 && exit 0
                          echo "SSH not ready yet... retrying"
                          sleep 10
                        done
                        echo "SSH did not become ready in time"
                        exit 1
                    """
                }
            }
        }

        stage('Deploy NextJob Platform') {
            steps {
                dir('ansible') {
                    sh '''
                        ansible-playbook -i inventory.ini playbook.yml \
                          --extra-vars "docker_image=${IMAGE_URI}"
                    '''
                }
            }
        }
    }

    post {
        always {
            sh 'docker image prune -f || true'
        }
        success {
            echo 'NextJob Platform pipeline completed successfully.'
        }
        failure {
            echo 'NextJob Platform pipeline failed.'
        }
    }
}